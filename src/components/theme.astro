---
import { Icon } from 'astro-icon/components'
---

<div class="relative ml-3" id="theme-menu-container">
  <div>
    <button
      type="button"
      class="dark:purple-700 inline-flex w-full justify-center rounded-md border border-purple-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 shadow-sm hover:bg-purple-100 focus:ring-2 focus:ring-purple-500 focus:ring-offset-2 focus:ring-offset-purple-300 focus:outline-none dark:bg-gray-800 dark:text-gray-100 dark:focus:ring-offset-purple-700"
      id="theme-menu-button"
      aria-expanded="false"
      aria-haspopup="true"
    >
      Light/Dark
      <Icon class="-mr-1 ml-2 h-5 w-5" aria-hidden="true" name="heroicons:chevron-down-20-solid" />
    </button>
  </div>
  <ul
    id="theme-menu-dropdown"
    class="ring-opacity-5 absolute z-20 mt-1 hidden max-h-56 w-full overflow-auto rounded-md bg-white py-1 text-base shadow-lg ring-1 ring-black focus:outline-none sm:text-sm dark:bg-gray-700"
    tabindex="-1"
    role="listbox"
    aria-labelledby="listbox-label"
  >
    <li
      class="relative cursor-default py-2 pr-4 pl-2 text-gray-900 select-none hover:bg-purple-600 hover:text-white dark:bg-gray-700 dark:text-white dark:hover:bg-purple-300 dark:hover:text-gray-900"
      id="theme-opt-system"
    >
      <div class="flex items-center">
        <Icon class="h-6 w-6" name="heroicons:star" />
        <span class="ml-1 block truncate font-normal" id="theme-label-system">System</span>
      </div>
      <span
        class="absolute inset-y-0 right-0 flex hidden items-center pr-4 text-purple-600 hover:text-white"
        id="theme-check-system"
      >
        <Icon class="h-5 w-5" name="heroicons:check-20-solid" />
      </span>
    </li>
    <li
      class="relative cursor-default py-2 pr-4 pl-2 text-gray-900 select-none hover:bg-purple-600 hover:text-white dark:bg-gray-700 dark:text-white dark:hover:bg-purple-300 dark:hover:text-gray-900"
      id="theme-opt-light"
    >
      <div class="flex items-center">
        <Icon class="h-6 w-6" name="heroicons:sun" />
        <span class="ml-1 block truncate font-normal" id="theme-label-light">Light</span>
      </div>
      <span
        class="absolute inset-y-0 right-0 flex hidden items-center pr-4 text-purple-600 hover:text-white"
        id="theme-check-light"
      >
        <Icon class="h-5 w-5" name="heroicons:check-20-solid" />
      </span>
    </li>
    <li
      class="relative cursor-default py-2 pr-4 pl-2 text-gray-900 select-none hover:bg-purple-600 hover:text-white dark:bg-gray-700 dark:text-white dark:hover:bg-purple-300 dark:hover:text-gray-900"
      id="theme-opt-dark"
    >
      <div class="flex items-center">
        <Icon class="h-6 w-6" name="heroicons:moon-solid" />
        <span class="ml-1 block truncate font-normal" id="theme-label-dark">Dark</span>
      </div>
      <span
        class="absolute inset-y-0 right-0 flex hidden items-center pr-4 text-purple-600 hover:text-white"
        id="theme-check-dark"
      >
        <Icon class="h-5 w-5" name="heroicons:check-20-solid" />
      </span>
    </li>
  </ul>
</div>

<script>
  function setupThemeMenu() {
    const container = document.getElementById('theme-menu-container')
    const btn = document.getElementById('theme-menu-button')
    const dropdown = document.getElementById('theme-menu-dropdown')

    const optSystem = document.getElementById('theme-opt-system')
    const optLight = document.getElementById('theme-opt-light')
    const optDark = document.getElementById('theme-opt-dark')

    const labelSystem = document.getElementById('theme-label-system')
    const labelLight = document.getElementById('theme-label-light')
    const labelDark = document.getElementById('theme-label-dark')

    const checkSystem = document.getElementById('theme-check-system')
    const checkLight = document.getElementById('theme-check-light')
    const checkDark = document.getElementById('theme-check-dark')

    if (btn && dropdown) {
      btn.addEventListener('click', (e) => {
        e.stopPropagation()
        const isOpen = !dropdown.classList.contains('hidden')
        if (isOpen) {
          dropdown.classList.add('hidden')
          btn.setAttribute('aria-expanded', 'false')
        } else {
          dropdown.classList.remove('hidden')
          btn.setAttribute('aria-expanded', 'true')
        }
      })

      document.addEventListener('click', (e) => {
        if (container && !container.contains(e.target as Node)) {
          dropdown.classList.add('hidden')
          btn.setAttribute('aria-expanded', 'false')
        }
      })
    }

    const currentTheme = localStorage.getItem('theme')
    if (!currentTheme) {
      labelSystem?.classList.add('font-semibold')
      checkSystem?.classList.remove('hidden')
    } else if (currentTheme === 'light') {
      labelLight?.classList.add('font-semibold')
      checkLight?.classList.remove('hidden')
    } else if (currentTheme === 'dark') {
      labelDark?.classList.add('font-semibold')
      checkDark?.classList.remove('hidden')
    }

    optSystem?.addEventListener('click', () => {
      localStorage.removeItem('theme')
      window.location.reload()
    })

    optLight?.addEventListener('click', () => {
      localStorage.theme = 'light'
      window.location.reload()
    })

    optDark?.addEventListener('click', () => {
      localStorage.theme = 'dark'
      window.location.reload()
    })
  }

  setupThemeMenu()
  document.addEventListener('astro:after-swap', setupThemeMenu)
</script>
