{
  "name": "hello-astro",
  "description": "Hello Astro is a full featured Astro corporate/marketing/blog starter theme written in Typescript and TailwindCSS. It supports Markdown and MDX based pages and blog posts.",
  "version": "5.3.0",
  "scripts": {
    "dev": "astro dev",
    "clean": "rm -rf node_modules .astro dist",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "lint": "pnpm run lint:prettier ; pnpm run lint:eslint",
    "lint:prettier": "prettier --write  \"src/**/*.{js,jsx,ts,tsx,md,mdx,astro}\"",
    "lint:eslint": "eslint --fix \"src/**/*.{js,ts,jsx,tsx,md,mdx,astro}\"",
    "refresh": "pnpm dlx @astrojs/upgrade; pnpm up -L",
    "astro": "astro"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@eslint/js": "^10.0.1",
    "@eslint/markdown": "^8.0.3",
    "@tailwindcss/typography": "^0.5.20",
    "@types/alpinejs": "^3.13.11",
    "eslint": "^10.6.0",
    "eslint-plugin-astro": "^2.1.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.7.0",
    "prettier": "^3.9.4",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0"
  },
  "dependencies": {
    "@astrojs/alpinejs": "^1.0.0",
    "@astrojs/markdoc": "^2.0.3",
    "@astrojs/mdx": "^7.0.2",
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.3",
    "@iconify-json/bi": "^1.2.7",
    "@iconify-json/heroicons": "^1.2.3",
    "@tailwindcss/vite": "^4.3.2",
    "alpinejs": "^3.15.12",
    "astro": "^7.0.7",
    "astro-icon": "^1.1.5",
    "astro-leaflet": "^1.12.0",
    "astro-masonry": "^1.2.2",
    "astro-mermaid": "^2.1.0",
    "astro-plantuml": "^0.1.4",
    "astro-robots-txt": "^1.0.0",
    "astro-seo": "^1.1.0",
    "astro-swiper": "^2.7.1",
